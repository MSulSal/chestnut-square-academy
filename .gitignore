# LocalWP runtime/config artifacts
/conf/
/logs/
/.npm-cache/

# WordPress core (do not track in this project repo)
/app/public/*

# Keep custom project code under wp-content
!/app/public/wp-content/
/app/public/wp-content/*
!/app/public/wp-content/plugins/
!/app/public/wp-content/themes/

# Ignore all plugins/themes by default
/app/public/wp-content/plugins/*
/app/public/wp-content/themes/*

# Keep only project-owned plugin/theme code
!/app/public/wp-content/plugins/csa-site-tools/
!/app/public/wp-content/plugins/csa-site-tools/**
!/app/public/wp-content/themes/hello-elementor-csa-site/
!/app/public/wp-content/themes/hello-elementor-csa-site/**

# Keep docs and root project files
!/docs/
!/docs/**
!/README.md
!/.gitignore

# Visual QA artifacts (keep render-pass screenshots local only)
/docs/local-*.png
/docs/live-*.png
/docs/compare-*.png
/docs/render-captures/


